	@echo "APPL????" > ../bin/release/OCAuxiliaryTools.app/Contents/PkgInfo
../bin/release/OCAuxiliaryTools.app/Contents/Info.plist: 
	@test -d ../bin/release/OCAuxiliaryTools.app/Contents || mkdir -p ../bin/release/OCAuxiliaryTools.app/Contents
	@$(DEL_FILE) ../bin/release/OCAuxiliaryTools.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /usr/local/share/qt/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.OCAuxiliaryTools,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.OCAuxiliaryTools,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},14.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,Icon.icns,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},Icon.icns,g" -e "s,@EXECUTABLE@,OCAuxiliaryTools,g" -e "s,@LIBRARY@,OCAuxiliaryTools,g" -e "s,\$${EXECUTABLE_NAME},OCAuxiliaryTools,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >../bin/release/OCAuxiliaryTools.app/Contents/Info.plist
